{
	"name": "@jrkropp/codex-js",
	"version": "0.3.0",
	"description": "Unofficial TypeScript Codex runtime for building Codex-backed web apps.",
	"license": "Apache-2.0",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"NOTICE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client/index.d.ts",
			"import": "./dist/client/index.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js"
		}
	},
	"scripts": {
		"build": "pnpm clean && tsup && tsc -p tsconfig.build.json --pretty false && node ../../scripts/fix-dts-extensions.mjs dist",
		"clean": "rm -rf dist",
		"pack:dry-run": "pnpm pack --dry-run",
		"publint": "publint",
		"typecheck": "tsc -p tsconfig.json --pretty false"
	},
	"dependencies": {
		"smol-toml": "^1.6.1"
	},
	"devDependencies": {
		"typescript": "5.8.3"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jrkropp/codex-js.git",
		"directory": "packages/codex-js"
	},
	"bugs": {
		"url": "https://github.com/jrkropp/codex-js/issues"
	},
	"homepage": "https://github.com/jrkropp/codex-js#readme"
}
